generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER

  @@map("ap_role")
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("ap_user_status")
}

enum InstrumentCategory {
  NON_AQUEOUS
  AQUEOUS

  @@map("ap_instrument_category")
}

enum InstrumentType {
  OVEN
  ULTRASONIC_BATH
  GLOVEBOX

  @@map("ap_instrument_type")
}

enum InstrumentStatus {
  AVAILABLE
  MAINTENANCE

  @@map("ap_instrument_status")
}

enum BookingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  AUTO_CANCELLED

  @@map("ap_booking_status")
}

enum BookingEventType {
  CREATED
  EDITED
  CANCELLED
  AUTO_CANCELLED
  COMPLETED
  REMOVED
  COMMENTED

  @@map("ap_booking_event_type")
}

enum BookingActorType {
  USER
  ADMIN
  SYSTEM

  @@map("ap_booking_actor_type")
}

enum ReagentStatus {
  AVAILABLE
  LOW
  OUT_OF_STOCK

  @@map("ap_reagent_status")
}

enum SonicatorMode {
  SONIC
  HEAT
  DEGAS

  @@map("ap_sonicator_mode")
}

// ─── Models ──────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  phone        String     @unique
  nickname     String?
  nim          String?    @unique
  supervisors  String[]
  hasSeenTour  Boolean    @default(false)
  image        String?    @db.Text
  passwordHash String     @map("password_hash")
  role         Role       @default(USER)
  status       UserStatus @default(PENDING)
  isContactPerson Boolean @default(false) @map("is_contact_person")
  emailVerified DateTime? @map("email_verified")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  bookings          Booking[]
  cancelledBookings Booking[]     @relation("booking_cancelled_by")
  deletedBookings   Booking[]     @relation("booking_deleted_by")
  bookingEvents     BookingEvent[] @relation("booking_event_actor")
  instrumentBans    InstrumentBan[]
  issuedBans        InstrumentBan[] @relation("ban_issued_by")
  reagents          Reagent[]       @relation("reagent_owner")
  glassware         Glassware[]     @relation("glassware_owner")
  glasswareLoans    GlasswareLoan[] @relation("glassware_borrower")
  announcements     Announcement[]
  reactions         Reaction[]

  @@map("ap_users")
}

model Instrument {
  id          Int                 @id @default(autoincrement())
  name        String
  type        InstrumentType      @default(OVEN)
  category    InstrumentCategory? 
  status      InstrumentStatus    @default(AVAILABLE)
  description String?
  maxTemp     Int                 @default(200) @map("max_temp")
  maxN2FlowRate Float?            @map("max_n2_flow_rate")

  bookings Booking[]

  @@map("ap_instruments")
}

model Booking {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  instrumentId Int           @map("instrument_id")
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  purpose      String
  usageTemp    Int?          @map("usage_temp")
  flap         Int?
  sonicatorModes SonicatorMode[] @map("sonicator_modes")
  equipmentBrought String?       @map("equipment_brought")
  chemicalsBrought String?       @map("chemicals_brought")
  n2FlowRate       Float?        @map("n2_flow_rate")
  n2Duration       Int?          @map("n2_duration")
  specialNotes     String?       @map("special_notes")
  status       BookingStatus @default(ACTIVE)
  cancelledAt  DateTime?     @map("cancelled_at")
  cancelledById String?      @map("cancelled_by_id")
  cancelReason String?       @map("cancel_reason")
  deletedAt    DateTime?     @map("deleted_at")
  deletedById  String?       @map("deleted_by_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  instrument   Instrument    @relation(fields: [instrumentId], references: [id])
  cancelledBy  User?         @relation("booking_cancelled_by", fields: [cancelledById], references: [id])
  deletedBy    User?         @relation("booking_deleted_by", fields: [deletedById], references: [id])
  events       BookingEvent[]

  @@index([instrumentId, startDate, endDate])
  @@index([deletedAt])
  @@map("ap_bookings")
}

model BookingEvent {
  id        String           @id @default(uuid())
  bookingId String           @map("booking_id")
  actorId   String?          @map("actor_id")
  actorType BookingActorType @default(SYSTEM) @map("actor_type")
  eventType BookingEventType @map("event_type")
  note      String?
  payload   Json?
  createdAt DateTime         @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor   User?   @relation("booking_event_actor", fields: [actorId], references: [id])

  @@index([bookingId, createdAt])
  @@index([actorId, createdAt])
  @@map("ap_booking_events")
}

model InstrumentBan {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  instrumentType InstrumentType @map("instrument_type")
  reason         String?
  bannedById     String         @map("banned_by_id")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  liftedAt       DateTime?      @map("lifted_at")

  user       User       @relation(fields: [userId], references: [id])
  bannedBy   User       @relation("ban_issued_by", fields: [bannedById], references: [id])

  @@unique([userId, instrumentType, isActive])
  @@map("ap_instrument_bans")
}

model Reagent {
  id          String        @id @default(uuid())
  customId    String?       @map("custom_id") // Optional explicit identifier like H-OAC_02
  name        String
  brand       String?
  casNumber   String?       @map("cas_number") // Catalog No
  quantity    String        // Legacy aggregate
  size        String?       // Numerical amount
  unit        String?       // mL, g, L
  arrivalDate String?       @map("arrival_date") // e.g. 2025/08
  condition   String?       // unopened, unsealed
  location    String?       // e.g., "Cabinet A", "Fridge 1"
  status      ReagentStatus @default(AVAILABLE)
  notes       String?       @db.Text
  synonyms    String?       @db.Text // Cached from PubChem API
  ownerId     String?       @map("owner_id") // Null means Lab Owned
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner       User?         @relation("reagent_owner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([ownerId])
  @@map("ap_reagents")
}

model Glassware {
  id          String   @id @default(uuid())
  customId    String?  @map("custom_id") // Optional explicit identifier
  name        String   // e.g. "Griffin Beaker"
  type        String   // e.g. "Beaker", "Flask"
  brand       String?
  size        String   // e.g. "250"
  unit        String   // e.g. "mL"
  quantity    Int      // Total stock count
  condition   String?  // e.g. "Good", "Chipped", "New"
  location    String?  // Storage location
  notes       String?  @db.Text
  ownerId     String?  @map("owner_id") // Null means Lab Owned
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       User?    @relation("glassware_owner", fields: [ownerId], references: [id], onDelete: SetNull)
  loans       GlasswareLoan[] @relation("glassware_loaned")

  @@index([name])
  @@index([type])
  @@index([ownerId])
  @@map("ap_glassware")
}

model GlasswareLoan {
  id          String     @id @default(uuid())
  glasswareId String     @map("glassware_id")
  userId      String     @map("user_id")
  quantity    Int
  purpose     String?    @db.Text
  borrowedAt  DateTime   @default(now()) @map("borrowed_at")
  returnedAt  DateTime?  @map("returned_at")
  status      LoanStatus @default(BORROWED)

  glassware   Glassware  @relation("glassware_loaned", fields: [glasswareId], references: [id])
  user        User       @relation("glassware_borrower", fields: [userId], references: [id])

  @@index([glasswareId])
  @@index([userId])
  @@map("ap_glassware_loans")
}

enum LoanStatus {
  PENDING_BORROW
  BORROWED
  PENDING_RETURN
  RETURNED
  REJECTED
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, token])
  @@map("ap_password_reset_tokens")
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("ap_email_otps")
}

model Announcement {
  id          String     @id @default(uuid())
  title       String
  content     String     @db.Text
  isPinned    Boolean    @default(false) @map("is_pinned")
  
  authorId    String     @map("author_id")
  author      User       @relation(fields: [authorId], references: [id])
  
  reactions   Reaction[]
  
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("ap_announcements")
}

model Reaction {
  id             String       @id @default(uuid())
  type           String       // e.g., "LIKE", "HEART", "CELEBRATE", etc.
  
  announcementId String       @map("announcement_id")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")

  // Ensure a user can only leave a specific type of reaction once per announcement
  @@unique([announcementId, userId, type])
  @@index([announcementId])
  @@index([userId])
  @@map("ap_reactions")
}
